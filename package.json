{
  "name": "claude-copilot",
  "displayName": "Claude Copilot",
  "description": "Claude Code 配置管理与辅助工具：plugins / MCP / skills / memory / settings / usage 一站式可视化",
  "version": "0.1.0",
  "publisher": "ky-studio",
  "repository": { "type": "git", "url": "https://github.com/ky-studio/claude-copilot.git" },
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCopilot",
          "title": "Claude Copilot",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claudeCopilot": [
        { "id": "claudeCopilot.plugins", "name": "Plugins" },
        { "id": "claudeCopilot.mcp", "name": "MCP Servers" },
        { "id": "claudeCopilot.skills", "name": "Skills" },
        { "id": "claudeCopilot.memory", "name": "Memory" },
        { "id": "claudeCopilot.settings", "name": "Settings" },
        { "id": "claudeCopilot.usage", "name": "Usage" }
      ]
    },
    "commands": [
      { "command": "claudeCopilot.refresh", "title": "Claude Copilot: Refresh All", "icon": "$(refresh)" },
      { "command": "claudeCopilot.openFile", "title": "Claude Copilot: Open File" },
      { "command": "claudeCopilot.openSettings", "title": "Claude Copilot: Open Settings File" },
      { "command": "claudeCopilot.openUsage", "title": "Claude Copilot: Open Usage Dashboard" },
      { "command": "claudeCopilot.plugin.install", "title": "Install Plugin...", "icon": "$(add)" },
      { "command": "claudeCopilot.plugin.uninstall", "title": "Uninstall" },
      { "command": "claudeCopilot.plugin.toggle", "title": "Toggle Enable" },
      { "command": "claudeCopilot.marketplace.add", "title": "Add Marketplace...", "icon": "$(add)" },
      { "command": "claudeCopilot.marketplace.remove", "title": "Remove Marketplace" },
      { "command": "claudeCopilot.mcp.addUser", "title": "Add User MCP...", "icon": "$(add)" },
      { "command": "claudeCopilot.mcp.addProject", "title": "Add Project MCP...", "icon": "$(add)" },
      { "command": "claudeCopilot.mcp.remove", "title": "Remove MCP Server" },
      { "command": "claudeCopilot.skill.create", "title": "Create Skill...", "icon": "$(add)" },
      { "command": "claudeCopilot.skill.delete", "title": "Delete Skill" },
      { "command": "claudeCopilot.memory.create", "title": "New Memory...", "icon": "$(add)" },
      { "command": "claudeCopilot.memory.delete", "title": "Delete Memory" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "claudeCopilot.openSettings", "when": "false" },
        { "command": "claudeCopilot.openFile", "when": "false" }
      ],
      "view/title": [
        { "command": "claudeCopilot.plugin.install", "when": "view == claudeCopilot.plugins", "group": "navigation@1" },
        { "command": "claudeCopilot.refresh", "when": "view == claudeCopilot.plugins", "group": "navigation@2" },
        { "command": "claudeCopilot.skill.create", "when": "view == claudeCopilot.skills", "group": "navigation@1" },
        { "command": "claudeCopilot.memory.create", "when": "view == claudeCopilot.memory", "group": "navigation@1" }
      ],
      "view/item/context": [
        { "command": "claudeCopilot.marketplace.add", "when": "view == claudeCopilot.plugins && viewItem == group:marketplaces", "group": "inline" },
        { "command": "claudeCopilot.marketplace.remove", "when": "view == claudeCopilot.plugins && viewItem == marketplace" },
        { "command": "claudeCopilot.plugin.toggle", "when": "view == claudeCopilot.plugins && viewItem =~ /^plugin:/", "group": "inline" },
        { "command": "claudeCopilot.plugin.uninstall", "when": "view == claudeCopilot.plugins && viewItem =~ /^plugin:/" },
        { "command": "claudeCopilot.mcp.addUser", "when": "view == claudeCopilot.mcp && viewItem == group:mcp:user", "group": "inline" },
        { "command": "claudeCopilot.mcp.addProject", "when": "view == claudeCopilot.mcp && viewItem == group:mcp:project", "group": "inline" },
        { "command": "claudeCopilot.mcp.remove", "when": "view == claudeCopilot.mcp && viewItem =~ /^mcp:/" },
        { "command": "claudeCopilot.skill.delete", "when": "view == claudeCopilot.skills && viewItem =~ /^skill:/" },
        { "command": "claudeCopilot.memory.delete", "when": "view == claudeCopilot.memory && viewItem == memory:item" }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --target=node18 --sourcemap && pnpm -C webview-ui build",
    "watch": "pnpm build -- --watch",
    "test": "mocha --require ts-node/register 'src/**/*.test.ts'",
    "package": "pnpm build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "~1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "mocha": "^10.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
