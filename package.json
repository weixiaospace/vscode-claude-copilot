{
  "name": "claude-copilot",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.17",
  "l10n": "./l10n",
  "publisher": "weixiao-space",
  "repository": { "type": "git", "url": "https://github.com/weixiaospace/vscode-claude-copilot.git" },
  "homepage": "https://github.com/weixiaospace/vscode-claude-copilot#readme",
  "bugs": { "url": "https://github.com/weixiaospace/vscode-claude-copilot/issues" },
  "keywords": ["claude", "copilot", "ai", "mcp", "plugins", "skills", "anthropic", "claude-code"],
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Machine Learning", "Other"],
  "icon": "resources/marketplace-icon.png",
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCopilot",
          "title": "Claude Copilot",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claudeCopilot": [
        { "id": "claudeCopilot.plugins", "name": "%view.plugins.name%" },
        { "id": "claudeCopilot.mcp", "name": "%view.mcp.name%" },
        { "id": "claudeCopilot.skills", "name": "%view.skills.name%" },
        { "id": "claudeCopilot.memory", "name": "%view.memory.name%" },
        { "id": "claudeCopilot.settings", "name": "%view.settings.name%" },
        { "id": "claudeCopilot.usage", "name": "%view.usage.name%" }
      ]
    },
    "commands": [
      { "command": "claudeCopilot.refresh", "title": "%cmd.refresh%", "icon": "$(refresh)" },
      { "command": "claudeCopilot.openFile", "title": "%cmd.openFile%" },
      { "command": "claudeCopilot.openSettingsPanel", "title": "%cmd.openSettingsPanel%", "icon": "$(gear)" },
      { "command": "claudeCopilot.openUsage", "title": "%cmd.openUsage%" },
      { "command": "claudeCopilot.openMarketplace", "title": "%cmd.openMarketplace%", "icon": "$(extensions)" },
      { "command": "claudeCopilot.plugin.install", "title": "%cmd.plugin.install%", "icon": "$(add)" },
      { "command": "claudeCopilot.plugin.uninstall", "title": "%cmd.plugin.uninstall%" },
      { "command": "claudeCopilot.plugin.toggle", "title": "%cmd.plugin.toggle%" },
      { "command": "claudeCopilot.marketplace.add", "title": "%cmd.marketplace.add%", "icon": "$(add)" },
      { "command": "claudeCopilot.marketplace.remove", "title": "%cmd.marketplace.remove%" },
      { "command": "claudeCopilot.marketplace.update", "title": "%cmd.marketplace.update%", "icon": "$(sync)" },
      { "command": "claudeCopilot.marketplace.updateAll", "title": "%cmd.marketplace.updateAll%", "icon": "$(sync)" },
      { "command": "claudeCopilot.mcp.addUser", "title": "%cmd.mcp.addUser%", "icon": "$(add)" },
      { "command": "claudeCopilot.mcp.addProject", "title": "%cmd.mcp.addProject%", "icon": "$(add)" },
      { "command": "claudeCopilot.mcp.remove", "title": "%cmd.mcp.remove%" },
      { "command": "claudeCopilot.skill.create", "title": "%cmd.skill.create%", "icon": "$(add)" },
      { "command": "claudeCopilot.skill.delete", "title": "%cmd.skill.delete%" },
      { "command": "claudeCopilot.memory.create", "title": "%cmd.memory.create%", "icon": "$(add)" },
      { "command": "claudeCopilot.memory.delete", "title": "%cmd.memory.delete%" },
      { "command": "claudeCopilot.providers.quickSwitch", "title": "%cmd.providers.quickSwitch%", "icon": "$(rocket)" },
      { "command": "claudeCopilot.providers.create", "title": "%cmd.providers.create%", "icon": "$(add)" },
      { "command": "claudeCopilot.providers.edit", "title": "%cmd.providers.edit%", "icon": "$(edit)" },
      { "command": "claudeCopilot.providers.delete", "title": "%cmd.providers.delete%", "icon": "$(trash)" },
      { "command": "claudeCopilot.providers.activateById", "title": "%cmd.providers.activateById%" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "claudeCopilot.openFile", "when": "false" },
        { "command": "claudeCopilot.providers.activateById", "when": "false" }
      ],
      "view/title": [
        { "command": "claudeCopilot.openMarketplace", "when": "view == claudeCopilot.plugins", "group": "navigation@0" },
        { "command": "claudeCopilot.plugin.install", "when": "view == claudeCopilot.plugins", "group": "navigation@1" },
        { "command": "claudeCopilot.refresh", "when": "view == claudeCopilot.plugins", "group": "navigation@2" },
        { "command": "claudeCopilot.skill.create", "when": "view == claudeCopilot.skills", "group": "navigation@1" },
        { "command": "claudeCopilot.memory.create", "when": "view == claudeCopilot.memory", "group": "navigation@1" }
      ],
      "view/item/context": [
        { "command": "claudeCopilot.marketplace.add", "when": "view == claudeCopilot.plugins && viewItem == group:marketplaces", "group": "inline@0" },
        { "command": "claudeCopilot.marketplace.updateAll", "when": "view == claudeCopilot.plugins && viewItem == group:marketplaces", "group": "inline@1" },
        { "command": "claudeCopilot.marketplace.update", "when": "view == claudeCopilot.plugins && viewItem == marketplace", "group": "inline" },
        { "command": "claudeCopilot.marketplace.remove", "when": "view == claudeCopilot.plugins && viewItem == marketplace" },
        { "command": "claudeCopilot.plugin.toggle", "when": "view == claudeCopilot.plugins && viewItem =~ /^plugin:/", "group": "inline" },
        { "command": "claudeCopilot.plugin.uninstall", "when": "view == claudeCopilot.plugins && viewItem =~ /^plugin:/" },
        { "command": "claudeCopilot.mcp.addUser", "when": "view == claudeCopilot.mcp && viewItem == group:mcp:user", "group": "inline" },
        { "command": "claudeCopilot.mcp.addProject", "when": "view == claudeCopilot.mcp && viewItem == group:mcp:project", "group": "inline" },
        { "command": "claudeCopilot.mcp.remove", "when": "view == claudeCopilot.mcp && viewItem =~ /^mcp:/" },
        { "command": "claudeCopilot.skill.delete", "when": "view == claudeCopilot.skills && viewItem =~ /^skill:/" },
        { "command": "claudeCopilot.memory.delete", "when": "view == claudeCopilot.memory && viewItem == memory:item" },
        { "command": "claudeCopilot.providers.create", "when": "view == claudeCopilot.settings && viewItem == profile-group", "group": "inline@0" },
        { "command": "claudeCopilot.providers.activateById", "when": "view == claudeCopilot.settings && viewItem == profile-subscription:inactive", "group": "inline@0" },
        { "command": "claudeCopilot.providers.activateById", "when": "view == claudeCopilot.settings && viewItem == profile:inactive", "group": "inline@0" },
        { "command": "claudeCopilot.providers.edit", "when": "view == claudeCopilot.settings && (viewItem == profile:active || viewItem == profile:inactive)", "group": "inline@1" },
        { "command": "claudeCopilot.providers.delete", "when": "view == claudeCopilot.settings && (viewItem == profile:active || viewItem == profile:inactive)", "group": "inline@2" }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --target=node18 --sourcemap && pnpm -C webview-ui build",
    "watch": "pnpm build -- --watch",
    "test": "mocha --require ts-node/register 'src/**/*.test.ts'",
    "package": "pnpm build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/vscode": "~1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "mocha": "^10.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
